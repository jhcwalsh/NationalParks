# ── NPS API (existing) ────────────────────────────────────────────────────────
NPS_API_KEY=your_nps_api_key_here

# ── Recreation.gov (campsite polling) ─────────────────────────────────────────
RECREATION_GOV_API_KEY=your_key_here

# ── Twilio (SMS + email) ─────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_sid
TWILIO_AUTH_TOKEN=your_token
TWILIO_FROM_NUMBER=+18005551234
TWILIO_SENDGRID_API_KEY=your_sendgrid_api_key
TWILIO_FROM_EMAIL=alerts@parkpulse.app

# ── AirNow (conditions enrichment) ───────────────────────────────────────────
AIRNOW_API_KEY=your_key

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=parkpulse.db

# ── Poller settings ──────────────────────────────────────────────────────────
POLL_INTERVAL_SECONDS=120
CANCELLATION_WINDOW_DAYS=14
